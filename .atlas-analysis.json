  "keyFeatures": [
    "Interactive and silent installation modes",
    "Native Ubuntu installation via apt packages",
    "Docker-based installation for non-Ubuntu systems",
    "Support for multiple ROS2 distributions (kilted, jazzy, iron, humble, rolling)",
    "Multiple package sets (minimal, base, desktop, desktop-full)",
    "System validation and verification",
    "Automatic rollback on installation failure",
    "YAML-based configuration",
    "Comprehensive logging and error handling",
    "Homebrew installation support"
  ],
  "publicApiSurface": [
    "ros2-installer (main command)",
    "--ros-distro <distro> (specify ROS2 distribution)",
    "--package-set <set> (minimal, base, desktop, desktop-full)",
    "--silent (non-interactive mode)",
    "--dry-run (simulate installation)",
    "--validate-only (check system requirements)",
    "--show-config (display configuration)",
    "--config <file> (custom YAML config)",
    "--log-level <level> (DEBUG, INFO, WARNING, ERROR)"
  ]
